[env]
# bir episode en fazla kaç saniye sürer (bu süre dolunca timeout)
time_limit = 25
# simülasyonun zaman adımı (saniye) — her adımda bu kadar ilerlenir
time_step = 0.25
# doğrulama setindeki senaryo sayısı
val_size = 100
# test setindeki senaryo sayısı
test_size = 500
# true yapılırsa insanların yarıçapı ve hızı rastgele belirlenir
randomize_attributes = false


[reward]
# hedefe ulaşınca alınan ödül
success_reward = 1
# çarpışma olunca verilen ceza
collision_penalty = -0.25
# bu mesafenin altına düşünce rahatsızlık cezası başlar (metre)
discomfort_dist = 0.2
# rahatsızlık cezasının çarpanı
discomfort_penalty_factor = 0.5


[sim]
# eğitim/doğrulama senaryosu tipi: circle_crossing veya square_crossing
train_val_sim = circle_crossing
# test senaryosu tipi
test_sim = circle_crossing
# kare geçiş senaryosunda alanın genişliği (metre)
square_width = 10
# daire geçiş senaryosunda dairenin yarıçapı (metre)
circle_radius = 4
# simülasyondaki insan sayısı
human_num = 5


[humans]
# insanlar robot tarafından görülebilir mi
visible = true
# insanların kullandığı navigasyon politikası
policy = orca
# insan yarıçapı (metre)
radius = 0.3
# insanın tercih ettiği yürüyüş hızı (m/s)
v_pref = 1
# algılama tipi: koordinat tabanlı (GPS gibi, tam pozisyon bilgisi)
sensor = coordinates


[robot]
# robot insanlar tarafından görülüyor mu (false = görünmez, daha zor senaryo)
visible = false
# robotun politikası (eğitim sırasında kod tarafından atanır)
policy = none
# robot yarıçapı (metre)
radius = 0.3
# robotun tercih ettiği hız (m/s)
v_pref = 1
# algılama tipi: koordinat tabanlı
sensor = coordinates
