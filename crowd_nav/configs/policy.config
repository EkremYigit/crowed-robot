# Robotun politika ayarları

[rl]
# gelecekteki ödüllerin bugünkü değeri — 1'e yaklaştıkça robot uzun vadeli düşünür
gamma = 0.9


[om]
# işgal haritasındaki hücre sayısı (cell_num x cell_num ızgara)
cell_num = 4
# her hücrenin boyutu (metre)
cell_size = 1
# her hücrede saklanan bilgi sayısı (1: var/yok, 2: +hız, 3: +yön)
om_channel_size = 3


[action_space]
# hareket tipi: holonomic = her yöne serbestçe gidebilir
kinematics = holonomic
# aksiyon uzayı boyutu = speed_samples * rotation_samples + 1 (dur aksiyonu)
speed_samples = 5
# kaç farklı açı denenir (360° / 16 = 22.5° aralıkla)
rotation_samples = 16
# hız örnekleme yöntemi: exponential = yavaş hızlara daha ince örnekleme
sampling = exponential
# true: her aksiyon için gerçek ORCA simülasyonu (~15x yavaş ama doğru)
# false: insanların mevcut hızlarında devam edeceğini varsay (hızlı, yeterince doğru)
query_env = false


[cadrl]
# değer ağının katman boyutları
mlp_dims = 150, 100, 100, 1
# false: sadece en yakın 1 insanla eğitim
multiagent_training = false


[lstm_rl]
# LSTM gizli katman boyutu
global_state_dim = 50
# özellik çıkarma katmanları
mlp1_dims = 150, 100, 100, 50
# değer tahmin katmanları
mlp2_dims = 150, 100, 100, 1
# true: tüm insanlarla aynı anda eğitim
multiagent_training = true
# occupancy map kullanılsın mı
with_om = false
# insan-insan etkileşim modülü eklensin mi
with_interaction_module = false


[srl]
mlp1_dims = 150, 100, 100, 50
mlp2_dims = 150, 100, 100, 1
multiagent_training = true
with_om = false


[sarl]
# özellik çıkarma katmanları (her insan için ayrı işlenir)
mlp1_dims = 150, 100
# dikkat mekanizması sonrası katmanlar
mlp2_dims = 100, 50
# hangi insana ne kadar dikkat edileceğini hesaplayan ağ
attention_dims = 100, 100, 1
# final değer tahmin katmanları
mlp3_dims = 150, 100, 100, 1
# true: tüm insanlarla aynı anda eğitim
multiagent_training = true
# occupancy map eklenir mi (true = OM-SARL olur)
with_om = false
# global ortalama durum dikkat hesabına katılsın mı
with_global_state = true
